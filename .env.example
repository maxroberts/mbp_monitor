# --- InfluxDB v1.x connection ---
# NOTE: credentials (user/password) are NOT stored here.
# They live in ~/.netrc — see README section "Credentials (~/.netrc)".
INFLUX_HOST=192.168.0.218
INFLUX_PORT=8086
INFLUX_DB=maxs_mbp
INFLUX_SSL=false
INFLUX_VERIFY_SSL=false
INFLUX_TIMEOUT=5
INFLUX_MEASUREMENT=system_metrics

# Optional: override the netrc machine name (default = INFLUX_HOST)
# NETRC_MACHINE=192.168.0.218

# Optional: alternate netrc location (default = ~/.netrc)
# NETRC_PATH=/Users/max/.netrc

# --- Service settings ---
# How often (seconds) to sample and push metrics
POLL_INTERVAL=10

# Override the host tag attached to every point. Defaults to socket.gethostname().
HOSTNAME_OVERRIDE=Maxs_MBP

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: explicit path to osx-cpu-temp binary (auto-detected if blank)
# OSX_CPU_TEMP_BIN=/usr/local/bin/osx-cpu-temp

# --- Escape hatch (NOT recommended) ---
# If for some reason you can't use ~/.netrc, you can set credentials here.
# These are only consulted as a fallback if no netrc entry is found.
# INFLUX_USER=
# INFLUX_PASSWORD=
